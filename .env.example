# ─── Supabase ──────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ─── AI — Anthropic (primary, all bot replies) ─────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
# Model used for all customer-facing replies. Override per-tenant via llm_configs table.
# Fast/cheap default: claude-haiku-4-5-20251001
# Better quality:     claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── AI — OpenRouter (vision only, KB document image extraction) ───────────────
# https://openrouter.ai → Keys → Create key
OPENROUTER_API_KEY=sk-or-v1-...
# Free vision model for image extraction (200 req/day free tier)
OPENROUTER_VISION_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free

# ─── Embeddings — Voyage AI (KB semantic search) ──────────────────────────────
# Free tier: 50M tokens/month — https://dash.voyageai.com
# If unset, KB falls back to keyword search (ILIKE) only.
VOYAGE_API_KEY=pa-...

# ─── WhatsApp — Meta Cloud API ────────────────────────────────────────────────
# https://developers.facebook.com → App → WhatsApp → API Setup
META_WHATSAPP_TOKEN=your-permanent-system-user-token
META_VERIFY_TOKEN=your-arbitrary-verify-string
META_PHONE_NUMBER_ID=your-phone-number-id
META_APP_SECRET=your-app-secret

# ─── WhatsApp — Twilio Sandbox (alternative provider) ────────────────────────
# https://console.twilio.com → Messaging → Try it out → WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── Payments — Razorpay ─────────────────────────────────────────────────────
# https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ─── Payments — PhonePe ──────────────────────────────────────────────────────
# https://developer.phonepe.com → Dashboard
PHONEPE_MERCHANT_ID=your-merchant-id
PHONEPE_SALT_KEY=your-salt-key
PHONEPE_SALT_INDEX=1
# Set to "production" when going live; anything else uses sandbox
PHONEPE_ENV=sandbox

# ─── Email — Resend ───────────────────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000

# Used by the Next.js web app (must be NEXT_PUBLIC_ for browser access)
NEXT_PUBLIC_API_URL=http://localhost:4000
