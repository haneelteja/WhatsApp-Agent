# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ─── OpenRouter (single key → any LLM provider) ──────────────────────────────
# Sign up at https://openrouter.ai → Keys → Create key
OPENROUTER_API_KEY=sk-or-v1-...

# Bot reply model — customer-facing, use a capable paid model
# Default: anthropic/claude-3.5-haiku  (~$0.80/M input tokens)
# Upgrade:  anthropic/claude-sonnet-4-5 (~$3/M input tokens, better quality)
# Budget:   openai/gpt-4o-mini          (~$0.15/M input tokens)
OPENROUTER_REPLY_MODEL=anthropic/claude-3.5-haiku

# Image extraction model — KB document ingestion only, free tier is fine
# Default: meta-llama/llama-3.2-11b-vision-instruct:free  (200 req/day free)
# Upgrade:  google/gemini-flash-1.5     (fast, cheap, high accuracy)
OPENROUTER_VISION_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free

# ─── Voyage AI (embeddings for KB RAG) ───────────────────────────────────────
# Free tier: 50M tokens/month — https://dash.voyageai.com
# If unset, KB entries are saved without embeddings (keyword search only).
VOYAGE_API_KEY=pa-...

# ─── Meta WhatsApp Cloud API ──────────────────────────────────────────────────
META_WHATSAPP_TOKEN=your-permanent-system-user-token
META_VERIFY_TOKEN=your-arbitrary-verify-string
META_PHONE_NUMBER_ID=your-phone-number-id
META_APP_SECRET=your-app-secret   # for webhook signature verification

# ─── PhonePe (Phase 2) ────────────────────────────────────────────────────────
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_BASE_URL=https://api.phonepe.com/apis/hermes

# ─── Redis / BullMQ ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@alphabot.in

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000

# Used by the Next.js web app (must be NEXT_PUBLIC_ to be available in the browser)
NEXT_PUBLIC_API_URL=http://localhost:4000
